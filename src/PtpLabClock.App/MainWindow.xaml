<Window x:Class="PtpLabClock.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Process Bus Timing Lab"
        Width="1280"
        Height="870"
        MinWidth="1180"
        MinHeight="780"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        FontFamily="{StaticResource AppFont}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Loaded="Window_Loaded" UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Window.Resources>
        <DataTemplate x:Key="EventLogTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="98"/>
                    <ColumnDefinition Width="64"/>
                    <ColumnDefinition Width="88"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat=HH:mm:ss.fff}" Foreground="{StaticResource SubtleTextBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="12"/>
                <TextBlock Grid.Column="1" Text="{Binding Severity}" Foreground="{StaticResource AccentBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="12" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="2" Text="{Binding Source}" Foreground="{StaticResource MutedTextBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="12"/>
                <TextBlock Grid.Column="3" Text="{Binding Message}" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" FontSize="12"/>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{StaticResource BgTopColor}" Offset="0"/>
                <GradientStop Color="{StaticResource BgBottomColor}" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F8FBFF" BorderBrush="#DCE7F4" BorderThickness="0,0,0,1" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="PTP Lab Clock Simulator" FontFamily="{StaticResource AppDisplayFont}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Border Background="#EFF4FF" BorderBrush="#DCE7FF" BorderThickness="1" CornerRadius="11" Padding="9,3" Margin="10,0,0,0">
                            <TextBlock Text="GPLv3 • LAB TIMING SUITE" Style="{StaticResource KickerText}" Foreground="{StaticResource AccentBrush}"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="Synthetic IEC 61850-9-3 timing simulator for quick visibility, analyzer validation, and fault scenario testing." Style="{StaticResource MutedBody}" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Style="{StaticResource StatusCard}" Margin="0,0,8,0" MinWidth="118">
                        <StackPanel>
                            <TextBlock Text="ENGINE" Style="{StaticResource KickerText}"/>
                            <TextBlock Text="{Binding StateText}" FontSize="13.5" FontWeight="SemiBold" Foreground="{StaticResource RunBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatusCard}" MinWidth="156">
                        <StackPanel>
                            <TextBlock Text="ADAPTER" Style="{StaticResource KickerText}"/>
                            <TextBlock Text="{Binding AdapterModeText}" FontSize="13.5" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Style="{StaticResource ModernScrollViewer}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,18,24,24">
                <Border Style="{StaticResource Card}" Margin="0,0,0,14" Padding="16,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="44"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.50*"/>
                            <ColumnDefinition Width="2.10*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="NETWORK ADAPTER" Style="{StaticResource KickerText}" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="PROFILE PRESET" Style="{StaticResource KickerText}" Margin="0,0,0,6"/>

                        <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                            <ToggleButton x:Name="AdapterDropDownButton" Style="{StaticResource ModernDropdownToggleButton}" Click="AdapterDropDownButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding SelectedAdapter.Description}"
                                               FontSize="13.5"
                                               FontWeight="Medium"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Grid Grid.Column="1" Width="22" Height="22" Margin="10,0,0,0" VerticalAlignment="Center">
                                        <Path Stroke="{StaticResource MutedTextBrush}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M 6 8 L 11 13 L 16 8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.RenderTransform>
                                                <RotateTransform x:Name="AdapterChevronRotate" Angle="0" CenterX="11" CenterY="10"/>
                                            </Path.RenderTransform>
                                        </Path>
                                    </Grid>
                                </Grid>
                            </ToggleButton>

                            <Popup x:Name="AdapterPopup"
                                   PlacementTarget="{Binding ElementName=AdapterDropDownButton}"
                                   Placement="Bottom"
                                   VerticalOffset="8"
                                   AllowsTransparency="True"
                                   StaysOpen="False"
                                   Closed="AdapterPopup_Closed">
                                <Border Width="{Binding ActualWidth, ElementName=AdapterDropDownButton}"
                                        Background="White"
                                        BorderBrush="#E4ECF7"
                                        BorderThickness="1"
                                        CornerRadius="20"
                                        Padding="12"
                                        SnapsToDevicePixels="True"
                                        UseLayoutRounding="True">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Available adapters" Style="{StaticResource KickerText}" Margin="4,0,0,8"/>
                                        <ListBox x:Name="AdapterListBox"
                                                 Grid.Row="1"
                                                 MaxHeight="236"
                                                 ItemsSource="{Binding Adapters}"
                                                 SelectedItem="{Binding SelectedAdapter, Mode=TwoWay}"
                                                 SelectionChanged="AdapterListBox_SelectionChanged"
                                                 ItemContainerStyle="{StaticResource DropdownListBoxItem}">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Description}" FontSize="13.5" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource SubtleTextBrush}" FontSize="10.8" TextTrimming="CharacterEllipsis"/>
                                                                <Border Background="#F2F6FE" BorderBrush="#E4ECF8" BorderThickness="1" CornerRadius="9" Padding="7,2" Margin="8,0,0,0">
                                                                    <TextBlock Text="{Binding ModeLabel}" Style="{StaticResource KickerText}"/>
                                                                </Border>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <Path Grid.Column="1" Margin="12,0,2,0" VerticalAlignment="Center" Fill="{StaticResource AccentBrush}" Data="M 2 8 L 6.8 12.8 L 16 3.6 L 17.8 5.4 L 6.8 16.4 L 0.2 9.8 Z">
                                                            <Path.Style>
                                                                <Style TargetType="Path">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Path.Style>
                                                        </Path>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>
                            </Popup>
                        </Grid>

                        <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource PanelSoftBrush}" CornerRadius="21" Padding="4" Height="44" Margin="0,0,16,0" VerticalAlignment="Center">
                            <Grid x:Name="PresetSegmentHost" SizeChanged="PresetSegmentHost_SizeChanged" SnapsToDevicePixels="True">
                                <Border x:Name="PresetIndicator" Background="#DDE9FF" CornerRadius="17" HorizontalAlignment="Left" BorderBrush="#C8DBFF" BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.06" Color="#7DA5FF"/>
                                    </Border.Effect>
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="PresetIndicatorTransform"/>
                                    </Border.RenderTransform>
                                </Border>
                                <UniformGrid Columns="3">
                                    <RadioButton x:Name="IecProfileButton" Content="IEC 61850" Style="{StaticResource SegmentTextRadioButton}" IsChecked="{Binding IsIecProfile, Mode=TwoWay}" GroupName="ProfilePreset" Checked="ProfileRadioButton_Checked" Tag="0"/>
                                    <RadioButton x:Name="AnalyzerProfileButton" Content="Analyzer" Style="{StaticResource SegmentTextRadioButton}" IsChecked="{Binding IsAnalyzerProfile, Mode=TwoWay}" GroupName="ProfilePreset" Checked="ProfileRadioButton_Checked" Tag="1"/>
                                    <RadioButton x:Name="GenericProfileButton" Content="Generic" Style="{StaticResource SegmentTextRadioButton}" IsChecked="{Binding IsGenericProfile, Mode=TwoWay}" GroupName="ProfilePreset" Checked="ProfileRadioButton_Checked" Tag="2"/>
                                </UniformGrid>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource QuietButton}" Height="44" Margin="0,0,10,0" MinWidth="88"/>
                            <Button Command="{Binding StartCommand}" Style="{StaticResource PrimaryButton}" Height="44" Margin="0,0,10,0" MinWidth="118"><TextBlock Text="Start Engine" Foreground="White" FontWeight="SemiBold"/></Button>
                            <Button Content="Stop" Command="{Binding StopCommand}" Style="{StaticResource SoftDangerButton}" Height="44" MinWidth="82"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.05*"/>
                        <ColumnDefinition Width="1.56*"/>
                        <ColumnDefinition Width="1.02*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,14,0" MinHeight="430" Padding="18,18,18,18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Clock Profile" Style="{StaticResource SectionTitle}"/>
                                <TextBlock Text="Lab identity and PTP quality fields for quick visibility tests." Style="{StaticResource MutedBody}" Margin="0,4,0,16" TextWrapping="Wrap"/>
                            </StackPanel>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="0,0,4,0">
                                    <TextBlock Text="DOMAIN NUMBER" Style="{StaticResource KickerText}"/>
                                    <TextBox Text="{Binding DomainNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,14"/>

                                    <TextBlock Text="CLOCK CLASS" Style="{StaticResource KickerText}"/>
                                    <TextBox Text="{Binding ClockClass, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,14"/>

                                    <TextBlock Text="SOURCE MAC" Style="{StaticResource KickerText}"/>
                                    <TextBox Text="{Binding SourceMac, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,14"/>

                                    <TextBlock Text="CLOCK IDENTITY" Style="{StaticResource KickerText}"/>
                                    <TextBox Text="{Binding ClockIdentity, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,4"/>
                                </StackPanel>
                            </ScrollViewer>

                            <Border Grid.Row="2" Background="{StaticResource WarnSoftBrush}" BorderBrush="#F4D39C" BorderThickness="1" CornerRadius="18" Padding="14" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="LAB ONLY" Style="{StaticResource KickerText}" Foreground="{StaticResource WarnBrush}"/>
                                    <TextBlock Text="Synthetic simulator for analyzer validation, not a timing-accuracy source." Foreground="#9A3412" FontSize="13" LineHeight="18" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,14,0" MinHeight="430" Padding="18,18,18,18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                                <TextBlock Text="Live Timing Flow" Style="{StaticResource SectionTitle}"/>
                                <TextBlock Text="Layer-2 PTP counters, Wireshark hinting, and runtime visibility." Style="{StaticResource MutedBody}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>

                            <UniformGrid Grid.Row="1" Columns="3" Rows="3">
                                <Border Style="{StaticResource MiniCard}" Background="{StaticResource RunSoftBrush}" Margin="0,0,10,10">
                                    <StackPanel>
                                        <TextBlock Text="ANNOUNCE TX" Style="{StaticResource KickerText}" Foreground="{StaticResource RunBrush}"/>
                                        <TextBlock Text="{Binding AnnounceTx}" FontSize="32" FontWeight="SemiBold" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MiniCard}" Background="{StaticResource AccentSoftBrush}" Margin="0,0,10,10">
                                    <StackPanel>
                                        <TextBlock Text="SYNC TX" Style="{StaticResource KickerText}" Foreground="{StaticResource AccentBrush}"/>
                                        <TextBlock Text="{Binding SyncTx}" FontSize="32" FontWeight="SemiBold" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MiniCard}" Background="{StaticResource CyanSoftBrush}" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="FOLLOW_UP TX" Style="{StaticResource KickerText}" Foreground="{StaticResource CyanBrush}"/>
                                        <TextBlock Text="{Binding FollowUpTx}" FontSize="32" FontWeight="SemiBold" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MiniCard}" Margin="0,0,10,10">
                                    <StackPanel>
                                        <TextBlock Text="PDELAY_REQ RX" Style="{StaticResource KickerText}"/>
                                        <TextBlock Text="{Binding PdelayReqRx}" FontSize="32" FontWeight="SemiBold" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MiniCard}" Margin="0,0,10,10">
                                    <StackPanel>
                                        <TextBlock Text="PDELAY_RESP TX" Style="{StaticResource KickerText}"/>
                                        <TextBlock Text="{Binding PdelayRespTx}" FontSize="32" FontWeight="SemiBold" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MiniCard}" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="PDELAY_FU TX" Style="{StaticResource KickerText}"/>
                                        <TextBlock Text="{Binding PdelayFollowUpTx}" FontSize="32" FontWeight="SemiBold" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MiniCard}" Background="#FFF0F1" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="ERRORS" Style="{StaticResource KickerText}" Foreground="#C02644"/>
                                        <TextBlock Text="{Binding Errors}" FontSize="32" FontWeight="SemiBold" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MiniCard}" Background="{StaticResource PanelSoftBrush}" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="WIRESHARK" Style="{StaticResource KickerText}"/>
                                        <TextBlock Text="eth.type ==" FontFamily="Cascadia Mono, Consolas" FontSize="13" Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0"/>
                                        <TextBlock Text="0x88f7" FontFamily="Cascadia Mono, Consolas" FontSize="20" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MiniCard}" Background="{StaticResource PanelSoftBrush}">
                                    <StackPanel>
                                        <TextBlock Text="STATUS NOTE" Style="{StaticResource KickerText}"/>
                                        <TextBlock Text="{Binding AdapterStatusText}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" LineHeight="17" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource Card}" MinHeight="430" Padding="18,18,18,18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                                <TextBlock Text="Scenario Player" Style="{StaticResource SectionTitle}"/>
                                <TextBlock Text="Trigger controlled lab conditions to validate analyzer diagnostics." Style="{StaticResource MutedBody}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="3,0,5,0">
                                    <Button Content="GM Lost" Command="{Binding ScenarioCommand}" CommandParameter="GM_LOST" Style="{StaticResource SoftWarnButton}" Margin="2,0,2,10"/>
                                    <Button Content="Missing Follow_Up" Command="{Binding ScenarioCommand}" CommandParameter="MISSING_FOLLOW_UP" Style="{StaticResource SoftWarnButton}" Margin="2,0,2,10"/>
                                    <Button Content="Clock Degraded" Command="{Binding ScenarioCommand}" CommandParameter="CLOCK_DEGRADED" Style="{StaticResource SoftWarnButton}" Margin="2,0,2,10"/>
                                    <Button Content="Sequence Jump" Command="{Binding ScenarioCommand}" CommandParameter="SEQUENCE_JUMP" Style="{StaticResource SoftPurpleButton}" Margin="2,0,2,10"/>
                                    <Button Content="GM Switch" Command="{Binding ScenarioCommand}" CommandParameter="GM_SWITCH" Style="{StaticResource SoftPurpleButton}" Margin="2,0,2,10"/>
                                    <Button Content="Stop Pdelay" Command="{Binding ScenarioCommand}" CommandParameter="STOP_PDELAY" Style="{StaticResource SoftDangerButton}" Margin="2,0,2,10"/>
                                    <Button Content="Reset Scenario" Command="{Binding ResetScenarioCommand}" Style="{StaticResource SoftNeutralButton}" Margin="2,4,2,0"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <Border Style="{StaticResource Card}" Padding="18,18,18,18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Event Timeline" Style="{StaticResource SectionTitle}"/>
                                <TextBlock Text="Engine, adapter, scenario, and Pdelay response journal." Style="{StaticResource MutedBody}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="{StaticResource PanelSoftBrush}" BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="1" CornerRadius="15" Padding="11,5" VerticalAlignment="Center">
                                <TextBlock Text="Max 300 events" Foreground="{StaticResource MutedTextBrush}" FontSize="11.5"/>
                            </Border>
                        </Grid>

                        <ListBox Grid.Row="1" MaxHeight="132" ScrollViewer.VerticalScrollBarVisibility="Auto" ItemsSource="{Binding Events}" ItemTemplate="{StaticResource EventLogTemplate}" ItemContainerStyle="{StaticResource TimelineListBoxItem}"/>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
